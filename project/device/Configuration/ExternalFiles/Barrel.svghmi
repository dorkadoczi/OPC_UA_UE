			<linearGradient id="Filling_1_Vertical" gradientUnits="userSpaceOnUse" x1="0" y1="58" x2="0" y2="24.4" hmi-bind:gradientTransform="rotate({{LocalProps.FluidRotation}}, 0, 0)">
