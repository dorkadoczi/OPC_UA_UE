     xmlns:hmi-element="http://svg.siemens.com/hmi/element/"
     xmlns:hmi-feature="http://svg.siemens.com/hmi/feature/"
     xmlns:hmi-event="http://svg.siemens.com/hmi/event/"
     viewBox="0 0 198 300"
     preserveAspectRatio="none">

	<hmi:self type="widget" displayName="TanksBarrel" name="extended.TanksBarrel" version="1.0.1" performanceClass="L">
		<hmi:paramDef name="BasicColor"          type="HmiColor"   default="0xFFEEEEEE"  />
		<hmi:paramDef name="FillLevelColor"      type="HmiColor"   default="0xFFFFA100"/>
		<hmi:paramDef name="FillLevelValue"      type="number"     default="50"/>
		<hmi:paramDef name="Minimum"             type="number"     default="0"/>
		<hmi:paramDef name="Maximum"             type="number"     default="100"/>
		<!-- <hmi:paramDef name="FluidRotation"       type="number"     default="0"/> -->
		<hmi:paramDef name="DisplayFillLevel"    type="boolean"    default="false"/>
		<hmi:paramDef name="DisplayFillMode"     type="number"     default="0"/>
	</hmi:self>

	<defs>
		<hmi:localDef name="Color"					  type="HmiColor"   hmi-bind:value="{{ParamProps.BasicColor}}"  />
		<hmi:localDef name="FillLevelValue"			  type="number"		hmi-bind:value="{{Converter.Bounds((ParamProps.FillLevelValue-ParamProps.Minimum)/(ParamProps.Maximum-ParamProps.Minimum), 0.0, 1.0)}}"/>
		<hmi:localDef name="DisplayFillingBar" 		  type="boolean"    hmi-bind:value="{{and( eq(ParamProps.DisplayFillMode, 0) , ParamProps.DisplayFillLevel ) }}"/>
		<hmi:localDef name="DisplayFillingReflection" type="boolean"    hmi-bind:value="{{and( eq(ParamProps.DisplayFillMode, 1) , ParamProps.DisplayFillLevel ) }}"/>
		<hmi:localDef name="FluidRotation" 			  type="number" 	hmi-bind:value="{{0}}"/>	<!-- if FluidRotation is used: hmi-bind:value="{{Converter.Bounds(ParamProps.FluidRotation, -90, 0.0)}}-->
	</defs>
